COMPOSE_PROJECT_NAME=healthcare-hms

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_APP_NAME=Healthcare HMS
NEXT_PUBLIC_ENV=development

# Backend
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
DATABASE_URL=jdbc:mysql://localhost:3306/hms_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DATABASE_USERNAME=hms_user
DATABASE_PASSWORD=hms_password
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=replace_with_64_characters_minimum
JWT_REFRESH_SECRET=replace_with_64_characters_minimum
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080
