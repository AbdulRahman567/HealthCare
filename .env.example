COMPOSE_PROJECT_NAME=healthcare-hms

# Frontend (also passed as Docker build args)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_APP_NAME=Healthcare HMS
NEXT_PUBLIC_ENV=development

# Backend
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
DATABASE_URL=jdbc:mysql://localhost:3306/hms_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DATABASE_USERNAME=hms_user
DATABASE_PASSWORD=hms_password
REDIS_HOST=localhost
REDIS_PORT=6379
# Use strong random secrets in staging/production and set JWT_ALLOW_INSECURE_SECRETS=false
JWT_SECRET=change-me-access-token-secret-key-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-token-secret-key-min-32-chars!
JWT_ALLOW_INSECURE_SECRETS=true
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost
BACKEND_URL=http://localhost:8080

# Multi-tenancy (header X-Tenant-ID is primary; subdomain resolver stays off until DNS wiring)
TENANT_SUBDOMAIN_RESOLUTION_ENABLED=false
